# Copy this to .env and fill in real values. DO NOT commit .env.

# --- LLM (for synthesis) ---
LLM_PROVIDER=anthropic        # anthropic | openai | gemini
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# --- Web search provider ---
WEB_SEARCH_PROVIDER=tavily    # tavily | serper | duckduckgo
TAVILY_API_KEY=               # https://tavily.com — free 1000 req/month
# SERPER_API_KEY=             # https://serper.dev — free 2500 req
# (DuckDuckGo needs no key but the duckduckgo-search package must be installed.)

# --- Cache backend ---
# Options: memory | filesystem | postgresql
CACHE_BACKEND=postgresql

# Required only when CACHE_BACKEND=postgresql
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:emil2005@localhost:5432/my_project

# Optional PostgreSQL tuning (defaults shown)
DB_CACHE_TABLE=cache_entries
DB_POOL_MIN=1
DB_POOL_MAX=5

# --- Filesystem cache (only used when CACHE_BACKEND=filesystem) ---
CACHE_DIR=./.cache

# --- Shared cache settings ---
CACHE_TTL_SECONDS=14400       # 4 hours

# --- Runtime ---
LOG_LEVEL=INFO
PER_SOURCE_TIMEOUT_SECONDS=10
MAX_SOURCES_PER_QUERY=3